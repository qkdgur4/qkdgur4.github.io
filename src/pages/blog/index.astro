---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/base-layout.astro';
import PostCard from '../../components/post-card.astro';
import TagBadge from '../../components/tag-badge.astro';

// Get all posts
const posts = await getCollection('blog', ({ data }) => !data.draft);

// Sort posts by date (newest first)
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Get unique categories and tags for the sidebar/header
const categories = [...new Set(posts.map((post) => post.data.category))].sort();
const tags = [...new Set(posts.map((post) => post.data.tags).flat())].sort();

const writingQueue = [
  {
    title: 'Alphacar architecture notes',
    description: '자동차 서비스 플랫폼을 MSA와 Kubernetes 구조로 나누고 운영 흐름을 만든 과정을 정리할 예정입니다.',
    tags: ['Kubernetes', 'MSA', 'GitOps'],
  },
  {
    title: 'AI observability log',
    description: 'Prometheus, Loki, Tempo, AWS Bedrock을 연결해 장애 신호를 분석하고 리포트하는 흐름을 기록할 예정입니다.',
    tags: ['Grafana', 'Bedrock', 'Ops'],
  },
  {
    title: 'Control-room portfolio refactor',
    description: '포트폴리오를 기술 블로그처럼 읽히게 만든 구조 변경과 디자인 결정을 남길 예정입니다.',
    tags: ['Astro', 'UI', 'Writing'],
  },
];
---

<BaseLayout title="Technical Logs | qkdgur4" description="qkdgur4의 백엔드, 인프라, Kubernetes, AI 관측성 기술 로그입니다." sideBarActiveItemID="blog">
  <div class="py-12">
    <header class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-4">
      <div>
        <p class="mb-3 text-sm font-bold uppercase tracking-widest text-blue-600 dark:text-blue-300">Technical Logs</p>
        <h1 class="text-4xl font-extrabold text-gray-900 dark:text-white mb-2 transition-colors">실험을 다시 읽을 수 있는 글로 남깁니다.</h1>
        <p class="text-gray-600 dark:text-gray-400 transition-colors">백엔드, 인프라, Kubernetes, 관측성 프로젝트에서 나온 선택과 트레이드오프를 정리합니다.</p>
      </div>
      <div class="text-sm font-medium text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 px-4 py-2 rounded-full border border-gray-200 dark:border-gray-700 transition-colors">
        Total <span class="text-blue-600 dark:text-blue-400">{posts.length}</span> posts
      </div>
    </header>

    <div class="flex flex-col md:flex-row gap-12">
      <!-- Main Content: Post Grid -->
      <div class="flex-grow">
        {sortedPosts.length > 0 ? (
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-2">
            {sortedPosts.map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        ) : (
          <div class="grid gap-4 md:grid-cols-2">
            {writingQueue.map((item) => (
              <article class="signal-card rounded-lg border border-gray-200 bg-white/70 p-5 dark:border-gray-800 dark:bg-gray-900/70">
                <p class="text-xs font-bold uppercase tracking-widest text-blue-600 dark:text-blue-300">Writing Queue</p>
                <h2 class="mt-3 text-xl font-extrabold text-gray-950 dark:text-white">{item.title}</h2>
                <p class="mt-3 text-sm leading-relaxed text-gray-600 dark:text-gray-300">{item.description}</p>
                <div class="mt-5 flex flex-wrap gap-2 border-t border-gray-200 pt-4 dark:border-gray-800">
                  {item.tags.map((tag) => (
                    <span class="rounded bg-emerald-100 px-2 py-1 text-xs font-semibold text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-300">#{tag}</span>
                  ))}
                </div>
              </article>
            ))}
          </div>
        )}
      </div>

      <!-- Sidebar: Categories & Tags -->
      <aside class="w-full md:w-64 flex-shrink-0 space-y-10">
        <div>
          <h2 class="text-xl font-bold text-gray-950 dark:text-white mb-4 flex items-center gap-2">
            Categories
          </h2>
          {categories.length > 0 ? (
            <ul class="space-y-2">
              {categories.map((cat) => (
                <li>
                  <a
                    href={`/blog/category/${cat.toLowerCase()}`}
                    class="text-gray-500 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400 transition-colors flex items-center justify-between"
                  >
                    <span>{cat}</span>
                    <span class="text-xs bg-gray-100 dark:bg-gray-800 px-2 py-0.5 rounded text-gray-500">
                      {posts.filter(p => p.data.category === cat).length}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-sm text-gray-500 dark:text-gray-400">첫 글이 올라오면 카테고리가 여기에 쌓입니다.</p>
          )}
        </div>

        <div>
          <h2 class="text-xl font-bold text-gray-950 dark:text-white mb-4 flex items-center gap-2">
            Tags
          </h2>
          {tags.length > 0 ? (
            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <TagBadge tag={tag} />
              ))}
            </div>
          ) : (
            <div class="flex flex-wrap gap-2">
              {writingQueue.flatMap((item) => item.tags).slice(0, 8).map((tag) => (
                <TagBadge tag={tag} />
              ))}
            </div>
          )}
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
