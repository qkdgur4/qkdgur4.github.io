---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/base-layout.astro';
import PostCard from '../components/post-card.astro';
import HorizontalCard from '../components/horizontal-card.astro';

// Get all posts and sort them by date (newest first)
const posts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = sortedPosts.slice(0, 3);
---

<BaseLayout title="Bang Hyuk | Portfolio" description="Software Engineer and Entrepreneur" sideBarActiveItemID="home">
  <!-- Hero Section -->
  <div class="pb-12 mt-5">
    <div class="text-xl py-1 text-gray-600 dark:text-gray-400 font-medium tracking-wide">Hey there 👋</div>
    <div class="text-5xl lg:text-6xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-blue-500 to-emerald-500 dark:from-blue-400 dark:to-emerald-400 my-2">
      I'm Bang Hyuk
    </div>
    <div class="text-2xl lg:text-3xl py-3 font-bold text-gray-900 dark:text-white">
      Software Engineer
    </div>
    <div class="py-4">
      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl leading-relaxed">
        This is a premium hybrid portfolio built with <b>Astro 6</b> and <b>Tailwind CSS v4</b>. 
        It combines beautiful glassmorphism gradients with a solid sidebar UX to present projects and technical articles effectively.
      </p>
    </div>
    <div class="mt-8 flex gap-4">
      <a href="mailto:contact@example.com" class="px-6 py-3 rounded-lg bg-blue-600 hover:bg-blue-500 text-white font-semibold transition-colors shadow-lg shadow-blue-500/20">
        Let's connect!
      </a>
      <a href="https://github.com/qkdgur4" target="_blank" class="px-6 py-3 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-900 dark:text-white font-semibold transition-colors border border-gray-300 dark:border-gray-700">
        GitHub Profile
      </a>
    </div>
  </div>

  <div class="border-b border-gray-200 dark:border-gray-800 my-8 transition-colors"></div>

  <!-- Projects Section (Horizontal) -->
  <section class="mb-12">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white flex items-center gap-3 transition-colors">
        My last projects {"</>"}
      </h2>
    </div>

    <div class="space-y-6">
      <HorizontalCard
        title="Seoul Simulator"
        img="https://images.unsplash.com/photo-1517430816045-df4b7de11d1d?w=800&q=80"
        desc="A massive concurrent simulation engine for Mapo-gu franchise analysis using LangGraph and AWS RDS."
        url="#"
        badge="NEW"
      />
      <HorizontalCard
        title="Slime Factory"
        img="https://images.unsplash.com/photo-1550745165-9bc0b252726f?w=800&q=80"
        desc="A hyper-casual mobile game with optimized backend infrastructure to reduce AWS operational costs by 80%."
        url="#"
        badge="FOSS"
      />
    </div>
  </section>

  <div class="border-b border-gray-200 dark:border-gray-800 my-12 transition-colors"></div>

  <!-- Blog Section (Grid) -->
  <section class="mb-12">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white transition-colors">
        Latest from blog
      </h2>
      <a href="/blog" class="text-sm text-blue-600 dark:text-blue-400 hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors font-medium">
        View all posts →
      </a>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      {recentPosts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </section>
</BaseLayout>
