---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/base-layout.astro';
import PostCard from '../components/post-card.astro';
import ProjectCard from '../components/project-card.astro';
import ControlRoomPanel from '../components/control-room-panel.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = sortedPosts.slice(0, 3);

const writingQueue = [
  {
    title: 'Control-room portfolio refactor',
    description: '홈페이지를 프로젝트, 글, 현재 작업 신호가 한 번에 보이는 기술 블로그 구조로 바꾸는 중입니다.',
    category: 'Portfolio',
    tags: ['Astro', 'UI', 'Writing'],
    href: '/projects',
    date: '2026.04.26',
  },
  {
    title: 'Alphacar architecture notes',
    description: 'MSA 서비스 경계, 멀티 클라우드 Kubernetes, GitOps 배포 흐름을 다음에 정리할 주제입니다.',
    category: 'Cloud Native',
    tags: ['Kubernetes', 'MSA', 'GitOps'],
    href: '/projects',
    date: 'next topic',
  },
  {
    title: 'AI observability log',
    description: 'Prometheus, Loki, Tempo, AWS Bedrock을 연결해 장애 신호를 분석하고 리포트하는 흐름을 다음에 정리할 주제입니다.',
    category: 'Observability',
    tags: ['Grafana', 'Bedrock', 'Ops'],
    href: '/projects',
    date: 'next topic',
  },
];

const featuredProjects = [
  {
    title: 'Alphacar Kubernetes Platform',
    eyebrow: 'MSA / Kubernetes / AI Observability',
    summary: '자동차 서비스 플랫폼을 MSA로 나누고, 멀티 클라우드 Kubernetes 환경과 AI 기반 관측성을 함께 구축한 인프라 프로젝트입니다.',
    status: 'Public / Built',
    role: 'Cloud Native / DevOps / Backend',
    problem: '여러 자동차 서비스 기능을 안정적으로 운영하려면 서비스 분리, 배포 자동화, 모니터링, 장애 분석 흐름이 한 구조 안에서 맞물려야 합니다.',
    build: 'Next.js와 NestJS 기반 애플리케이션을 Kubernetes에 올리고, AWS EKS와 GCP GKE, ArgoCD, Terraform, Prometheus/Grafana/Loki/Tempo, AWS Bedrock을 연결했습니다.',
    result: '서비스 배포부터 메트릭, 로그, 트레이스 분석과 AI 리포팅까지 이어지는 클라우드 네이티브 운영 흐름을 프로젝트 형태로 정리했습니다.',
    evidence: ['7개 이상 마이크로서비스를 Kubernetes 환경에서 운영하도록 구성', 'AWS Bedrock 기반 모니터링 분석, Slack 알림, k6 성능 리포트 흐름 포함'],
    visual: {
      src: '/projects/alphacar-k8s-platform.svg',
      alt: 'Alphacar Kubernetes multi-cloud platform diagram',
      caption: 'MSA, GitOps, observability architecture',
    },
    stack: ['Kubernetes', 'AWS EKS', 'GCP GKE', 'ArgoCD', 'Terraform', 'Bedrock'],
    links: [
      { label: 'Repository', href: 'https://github.com/qkdgur4/alphacar-k8s' },
      { label: 'Case study', href: '/projects' },
    ],
    featured: true,
  },
  {
    title: 'qkdgur4.github.io',
    eyebrow: 'Portfolio / Technical Writing',
    summary: 'Astro 기반 블로그 자체를 기술 기록과 포트폴리오 증거가 함께 보이는 컨트롤룸으로 다듬는 프로젝트입니다.',
    status: 'Shipped / Improving',
    role: 'Frontend / Writing System',
    problem: '템플릿 느낌이 남아 있으면 방문자가 qkdgur4가 무엇을 만들고 어떤 문제를 다루는지 빠르게 알기 어렵습니다.',
    build: '히어로 문구, 프로젝트 카드, 기술 로그, OG 메타데이터를 한국어 우선의 작업 기록 구조로 재구성합니다.',
    result: '정적인 링크 모음에서 현재 작업, 케이스 스터디, 글감이 함께 보이는 살아있는 기술 블로그로 바뀝니다.',
    evidence: ['Live GitHub Pages site', 'Repository link available', 'Control-room UI and project evidence fields implemented'],
    visual: {
      src: '/projects/github-blog-control-room.svg',
      alt: 'qkdgur4 blog control-room information architecture diagram',
      caption: 'Information architecture diagram',
    },
    stack: ['Astro', 'Tailwind CSS', 'MDX', 'GitHub Pages'],
    links: [
      { label: 'Repository', href: 'https://github.com/qkdgur4/qkdgur4.github.io' },
      { label: 'Roadmap in repo' },
    ],
  },
];
---

<BaseLayout title="qkdgur4 | 실행되는 서비스로 바꾸는 개발 기록" description="백엔드, 인프라, Kubernetes, AI 관측성 프로젝트를 실제로 굴러가는 구조로 정리하는 qkdgur4의 기술 블로그입니다." sideBarActiveItemID="home">
  <section class="grid gap-8 pb-14 pt-6 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
    <div>
      <p class="mb-4 inline-flex rounded-md border border-blue-200 bg-blue-50 px-3 py-1 text-xs font-bold uppercase tracking-widest text-blue-700 dark:border-blue-500/30 dark:bg-blue-500/10 dark:text-blue-300">
        Backend / Infra / Cloud Native
      </p>
      <h1 class="text-4xl font-extrabold leading-tight text-gray-950 dark:text-white sm:text-5xl lg:text-6xl">
        아이디어를 실제로 굴러가는 서비스로 바꾸는 개발자, qkdgur4입니다.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-gray-600 dark:text-gray-300">
        백엔드와 인프라를 중심으로 Kubernetes, GitOps, 관측성, 자동화 실험을 만들고 그 과정의 선택과 시행착오를 기술 글로 남깁니다.
        빠른 실험을 운영 가능한 구조로 옮기고, 결과를 다시 읽을 수 있는 기록으로 정리하는 데 관심이 있습니다.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/projects" class="rounded-lg bg-blue-600 px-5 py-3 text-sm font-bold text-white shadow-lg shadow-blue-500/20 transition-colors hover:bg-blue-500">
          프로젝트 보기
        </a>
        <a href="/blog" class="rounded-lg border border-gray-300 px-5 py-3 text-sm font-bold text-gray-800 transition-colors hover:border-blue-500 hover:text-blue-600 dark:border-gray-700 dark:text-gray-100 dark:hover:border-blue-400 dark:hover:text-blue-300">
          기술 글 읽기
        </a>
        <a href="https://github.com/qkdgur4" target="_blank" rel="noopener noreferrer" class="rounded-lg border border-gray-300 px-5 py-3 text-sm font-bold text-gray-800 transition-colors hover:border-emerald-500 hover:text-emerald-600 dark:border-gray-700 dark:text-gray-100 dark:hover:border-emerald-400 dark:hover:text-emerald-300">
          GitHub
        </a>
      </div>
    </div>

    <ControlRoomPanel
      title="Now Building"
      commands={[
        { command: 'portfolio case studies with real evidence', active: true },
        { command: 'alphacar-k8s as the main infrastructure proof' },
        { command: 'technical writing from shipped repositories' },
      ]}
      metrics={[
        { label: 'case studies', value: '2', tone: 'blue' },
        { label: 'real repos', value: '2', tone: 'emerald' },
        { label: 'next topics', value: '3', tone: 'cyan' },
      ]}
      rows={[
        { label: 'Focus', value: 'runtime-ready ideas' },
        { label: 'Mode', value: 'build, measure, write' },
        { label: 'Signal', value: 'problem to output' },
        { label: 'Stack', value: 'backend first' },
      ]}
    />
  </section>

  <div class="border-b border-gray-200 dark:border-gray-800 my-8 transition-colors"></div>

  <section class="mb-12">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white transition-colors">
        Recent Technical Logs
      </h2>
      <a href="/blog" class="text-sm font-bold text-blue-600 transition-colors hover:text-emerald-600 dark:text-blue-400 dark:hover:text-emerald-300">
        전체 글 보기 &rarr;
      </a>
    </div>

    {recentPosts.length > 0 ? (
      <div class="grid gap-6 lg:grid-cols-2">
        {recentPosts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    ) : (
      <div class="grid gap-4 lg:grid-cols-3">
        {writingQueue.map((log) => (
          <a href={log.href} class="signal-card rounded-lg border border-gray-200 bg-white/70 p-5 transition-all hover:-translate-y-1 hover:border-blue-400 dark:border-gray-800 dark:bg-gray-900/70 dark:hover:border-blue-500">
            <div class="flex items-center justify-between gap-3">
              <span class="rounded-md border border-blue-200 bg-blue-50 px-2.5 py-1 text-xs font-bold text-blue-700 dark:border-blue-500/20 dark:bg-blue-500/10 dark:text-blue-300">{log.category}</span>
              <span class="text-xs font-mono text-gray-500 dark:text-gray-400">{log.date}</span>
            </div>
            <h3 class="mt-4 text-lg font-extrabold text-gray-950 dark:text-white">{log.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-gray-600 dark:text-gray-300">{log.description}</p>
            <div class="mt-5 flex flex-wrap gap-2 border-t border-gray-200 pt-4 dark:border-gray-800">
              {log.tags.map((tag) => (
                <span class="rounded bg-emerald-100 px-2 py-1 text-xs font-semibold text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-300">#{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

  <div class="border-b border-gray-200 dark:border-gray-800 my-12 transition-colors"></div>

  <section class="mb-12">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white transition-colors">
        Featured Case Studies
      </h2>
      <a href="/projects" class="text-sm font-bold text-blue-600 transition-colors hover:text-emerald-600 dark:text-blue-400 dark:hover:text-emerald-300">
        케이스 전체 보기 &rarr;
      </a>
    </div>

    <div class="space-y-6">
      {featuredProjects.map((project) => (
        <ProjectCard {...project} />
      ))}
    </div>
  </section>

  <div class="border-b border-gray-200 dark:border-gray-800 my-12 transition-colors"></div>

  <section class="rounded-lg border border-gray-200 bg-white/60 p-6 dark:border-gray-800 dark:bg-gray-900/60">
    <p class="text-sm font-bold uppercase tracking-widest text-blue-600 dark:text-blue-300">About Snapshot</p>
    <h2 class="mt-3 text-2xl font-extrabold text-gray-950 dark:text-white">작게 만들고, 실제로 굴리고, 다시 읽을 수 있게 기록합니다.</h2>
    <p class="mt-3 max-w-3xl leading-relaxed text-gray-600 dark:text-gray-300">
      이 블로그는 제품 아이디어를 백엔드 현실과 연결하는 작업대입니다. 문제, 구현, 결과, 다음 실험을 같은 화면에서 따라갈 수 있게 정리합니다.
    </p>
  </section>
</BaseLayout>
