---
import BaseLayout from '../layouts/base-layout.astro';
---

<BaseLayout title="About Me | DevBlog" description="About the author." sideBarActiveItemID="about">
  <div class="py-12">
    <header class="mb-12">
      <h1 class="text-4xl font-extrabold text-gray-900 dark:text-white mb-4 transition-colors">About Me</h1>
    </header>
    
    <article class="prose prose-blue dark:prose-invert max-w-none transition-colors">
      <p class="text-xl text-gray-600 dark:text-gray-300 leading-relaxed mb-8 transition-colors">
        Hello! I'm Manuel Ernesto, a Software Engineer and Entrepreneur passionate about building scalable cloud architectures, optimizing backend infrastructures, and crafting premium user experiences.
      </p>

      <h2>Experience</h2>
      <ul class="space-y-4">
        <li>
          <strong>Senior Backend Engineer</strong> - Tech Corp (2022 - Present)
          <p class="text-gray-500 dark:text-gray-400 mt-1 transition-colors">Leading the backend infrastructure team, managing AWS deployments, and optimizing high-concurrency systems.</p>
        </li>
        <li>
          <strong>Software Engineer</strong> - Startup Inc (2019 - 2022)
          <p class="text-gray-500 dark:text-gray-400 mt-1 transition-colors">Developed hyper-casual games and built automated CI/CD pipelines.</p>
        </li>
      </ul>

      <h2>Skills</h2>
      <div class="flex flex-wrap gap-2 mt-4">
        <span class="px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-lg border border-gray-200 dark:border-gray-700 transition-colors">TypeScript</span>
        <span class="px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-lg border border-gray-200 dark:border-gray-700 transition-colors">Node.js</span>
        <span class="px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-lg border border-gray-200 dark:border-gray-700 transition-colors">Astro</span>
        <span class="px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-lg border border-gray-200 dark:border-gray-700 transition-colors">AWS</span>
        <span class="px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-lg border border-gray-200 dark:border-gray-700 transition-colors">Docker</span>
      </div>
    </article>
  </div>
</BaseLayout>
