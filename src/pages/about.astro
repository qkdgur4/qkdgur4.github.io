---
import BaseLayout from '../layouts/base-layout.astro';
---

<BaseLayout title="About Me | DevBlog" description="About the author." sideBarActiveItemID="about">
  <div class="py-12">
    <header class="mb-12">
      <h1 class="text-4xl font-extrabold text-white mb-4">About Me</h1>
    </header>
    
    <article class="prose prose-invert prose-blue max-w-none">
      <p class="text-xl text-gray-300 leading-relaxed mb-8">
        Hello! I'm Manuel Ernesto, a Software Engineer and Entrepreneur passionate about building scalable cloud architectures, optimizing backend infrastructures, and crafting premium user experiences.
      </p>

      <h2>Experience</h2>
      <ul class="space-y-4">
        <li>
          <strong>Senior Backend Engineer</strong> - Tech Corp (2022 - Present)
          <p class="text-gray-400 mt-1">Leading the backend infrastructure team, managing AWS deployments, and optimizing high-concurrency systems.</p>
        </li>
        <li>
          <strong>Software Engineer</strong> - Startup Inc (2019 - 2022)
          <p class="text-gray-400 mt-1">Developed hyper-casual games and built automated CI/CD pipelines.</p>
        </li>
      </ul>

      <h2>Skills</h2>
      <div class="flex flex-wrap gap-2 mt-4">
        <span class="px-3 py-1 bg-gray-800 text-gray-300 rounded-lg border border-gray-700">TypeScript</span>
        <span class="px-3 py-1 bg-gray-800 text-gray-300 rounded-lg border border-gray-700">Node.js</span>
        <span class="px-3 py-1 bg-gray-800 text-gray-300 rounded-lg border border-gray-700">Astro</span>
        <span class="px-3 py-1 bg-gray-800 text-gray-300 rounded-lg border border-gray-700">AWS</span>
        <span class="px-3 py-1 bg-gray-800 text-gray-300 rounded-lg border border-gray-700">Docker</span>
      </div>
    </article>
  </div>
</BaseLayout>
