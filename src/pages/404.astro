---
import BaseLayout from '../layouts/base-layout.astro';
---

<BaseLayout title="404: Not Found | DevBlog" description="The page you are looking for does not exist.">
  <div class="min-h-[60vh] flex flex-col items-center justify-center text-center">
    <h1 class="text-9xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-blue-500 to-emerald-500 mb-4 tracking-tighter">
      404
    </h1>
    <h2 class="text-3xl font-bold text-white mb-6">Page Not Found</h2>
    <p class="text-gray-400 text-lg max-w-md mb-8">
      Oops! The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.
    </p>
    <a 
      href="/" 
      class="px-8 py-3 rounded-lg bg-blue-600 hover:bg-blue-500 text-white font-semibold transition-colors shadow-lg shadow-blue-500/20"
    >
      Return Home
    </a>
  </div>
</BaseLayout>
