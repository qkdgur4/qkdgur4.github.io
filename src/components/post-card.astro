---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;

const formattedDate = post.data.pubDate.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group relative flex flex-col items-start justify-between p-6 bg-gray-800/50 backdrop-blur-sm rounded-2xl border border-gray-700 hover:border-blue-500/50 hover:bg-gray-800 transition-all duration-300">
  <div class="flex items-center gap-x-4 text-xs mb-4">
    <time datetime={post.data.pubDate.toISOString()} class="text-gray-400">
      {formattedDate}
    </time>
    <a
      href={`/blog/category/${post.data.category.toLowerCase()}`}
      class="relative z-10 rounded-full bg-gray-700 px-3 py-1.5 font-medium text-gray-200 hover:bg-gray-600 transition-colors"
    >
      {post.data.category}
    </a>
  </div>
  
  <div class="group relative">
    <h3 class="mt-3 text-xl font-semibold leading-6 text-white group-hover:text-blue-400 transition-colors line-clamp-2" transition:name={`post-title-${post.data.title}`}>
      <a href={`/blog/${post.id}`}>
        <span class="absolute inset-0"></span>
        {post.data.title}
      </a>
    </h3>
    <p class="mt-3 line-clamp-3 text-sm leading-6 text-gray-400">
      {post.data.description}
    </p>
  </div>
  
  <div class="mt-6 flex flex-wrap gap-2">
    {post.data.tags.map((tag: string) => (
      <span class="text-xs text-emerald-400/80 bg-emerald-900/20 px-2 py-1 rounded">
        #{tag}
      </span>
    ))}
  </div>
</article>
