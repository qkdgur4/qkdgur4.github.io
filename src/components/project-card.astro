---
interface ProjectLink {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  eyebrow: string;
  summary: string;
  problem: string;
  build: string;
  result: string;
  stack: string[];
  links?: ProjectLink[];
  featured?: boolean;
}

const {
  title,
  eyebrow,
  summary,
  problem,
  build,
  result,
  stack,
  links = [],
  featured = false,
} = Astro.props;
---

<article class={`signal-card group relative overflow-hidden rounded-lg border bg-white/70 p-6 transition-all duration-300 dark:bg-gray-900/70 ${featured ? 'border-blue-300 shadow-lg shadow-blue-500/10 dark:border-blue-500/40' : 'border-gray-200 dark:border-gray-800'} hover:-translate-y-1 hover:border-blue-400 dark:hover:border-blue-500`}>
  <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-blue-500 via-cyan-400 to-emerald-400 opacity-80"></div>

  <div class="flex flex-col gap-4">
    <div class="relative">
      <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-blue-600 dark:text-blue-300">
        {eyebrow}
      </p>
      <h3 class="text-2xl font-extrabold text-gray-950 dark:text-white">
        {title}
      </h3>
      <p class="mt-3 text-sm leading-relaxed text-gray-600 dark:text-gray-300">
        {summary}
      </p>
    </div>

    <dl class="relative grid gap-3 text-sm sm:grid-cols-3">
      <div class="rounded-lg border border-gray-200 bg-gray-50 p-3 dark:border-gray-800 dark:bg-gray-950/60">
        <dt class="mb-1 font-bold text-gray-950 dark:text-white">Problem</dt>
        <dd class="leading-relaxed text-gray-600 dark:text-gray-400">{problem}</dd>
      </div>
      <div class="rounded-lg border border-gray-200 bg-gray-50 p-3 dark:border-gray-800 dark:bg-gray-950/60">
        <dt class="mb-1 font-bold text-gray-950 dark:text-white">Build</dt>
        <dd class="leading-relaxed text-gray-600 dark:text-gray-400">{build}</dd>
      </div>
      <div class="rounded-lg border border-gray-200 bg-gray-50 p-3 dark:border-gray-800 dark:bg-gray-950/60">
        <dt class="mb-1 font-bold text-gray-950 dark:text-white">Result</dt>
        <dd class="leading-relaxed text-gray-600 dark:text-gray-400">{result}</dd>
      </div>
    </dl>

    <div class="relative flex flex-col gap-4 border-t border-gray-200 pt-4 dark:border-gray-800 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex flex-wrap gap-2">
        {stack.map((item) => (
          <span class="rounded-md border border-emerald-200 bg-emerald-50 px-2.5 py-1 text-xs font-semibold text-emerald-700 dark:border-emerald-500/20 dark:bg-emerald-500/10 dark:text-emerald-300">
            {item}
          </span>
        ))}
      </div>

      <div class="flex flex-wrap gap-2">
        {links.map((link) => (
          link.href ? (
            <a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined} class="rounded-md border border-gray-300 px-3 py-1.5 text-xs font-bold text-gray-700 transition-colors hover:border-blue-500 hover:text-blue-600 dark:border-gray-700 dark:text-gray-300 dark:hover:border-blue-400 dark:hover:text-blue-300">
              {link.label}
            </a>
          ) : (
            <span class="rounded-md border border-gray-200 px-3 py-1.5 text-xs font-bold text-gray-400 dark:border-gray-800 dark:text-gray-500">
              {link.label}
            </span>
          )
        ))}
      </div>
    </div>
  </div>
</article>
