---
interface Props {
  title: string;
  img: string;
  desc: string;
  url: string;
  badge?: string;
}

const { title, img, desc, url, badge } = Astro.props;
---

<a href={url} class="block group">
  <div class="flex flex-col md:flex-row bg-white/50 dark:bg-gray-800/50 backdrop-blur-md border border-gray-200 dark:border-gray-700/50 rounded-xl overflow-hidden hover:bg-gray-50 dark:hover:bg-gray-800/80 hover:border-blue-400 dark:hover:border-blue-500/50 hover:shadow-[0_0_20px_rgba(59,130,246,0.15)] transition-all duration-300">
    <div class="md:w-1/3 aspect-video md:aspect-auto overflow-hidden bg-gray-100 dark:bg-gray-900">
      <img src={img} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
    </div>
    <div class="md:w-2/3 p-6 flex flex-col justify-center">
      <div class="flex items-start justify-between gap-4 mb-2">
        <h3 class="text-xl font-bold text-gray-900 dark:text-white group-hover:text-blue-500 dark:group-hover:text-blue-400 transition-colors line-clamp-2">
          {title}
        </h3>
        {badge && (
          <span class="shrink-0 px-2.5 py-1 text-xs font-semibold bg-emerald-100 dark:bg-emerald-500/20 text-emerald-600 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-500/30 rounded-md">
            {badge}
          </span>
        )}
      </div>
      <p class="text-gray-600 dark:text-gray-400 line-clamp-3">
        {desc}
      </p>
    </div>
  </div>
</a>
