---
interface StatusItem {
  label: string;
  value: string;
}

interface CommandItem {
  command: string;
  active?: boolean;
}

interface MetricItem {
  label: string;
  value: string;
  tone?: 'blue' | 'emerald' | 'cyan';
}

interface Props {
  title: string;
  status?: string;
  commands: CommandItem[];
  metrics?: MetricItem[];
  rows?: StatusItem[];
}

const { title, status = 'active', commands, metrics = [], rows = [] } = Astro.props;

const toneClass = {
  blue: 'text-blue-600 dark:text-blue-300',
  emerald: 'text-emerald-600 dark:text-emerald-300',
  cyan: 'text-cyan-600 dark:text-cyan-300',
};
---

<aside class="scanline control-grid rounded-lg border border-gray-200 bg-white/80 p-5 shadow-xl shadow-gray-900/5 dark:border-gray-800 dark:bg-gray-950/80 dark:shadow-black/20">
  <div class="mb-4 flex items-center justify-between border-b border-gray-200 pb-3 dark:border-gray-800">
    <span class="text-sm font-bold text-gray-900 dark:text-white">{title}</span>
    <span class="rounded-full bg-emerald-100 px-2 py-1 text-xs font-bold text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-300">{status}</span>
  </div>

  <div class="space-y-3 font-mono text-sm">
    {commands.map((item) => (
      <div class="flex items-start gap-3">
        <span class="text-blue-500">$</span>
        <p class:list={[
          'text-gray-700 dark:text-gray-300',
          item.active && 'terminal-caret',
        ]}>
          {item.command}
        </p>
      </div>
    ))}
  </div>

  {metrics.length > 0 && (
    <div class="mt-5 grid grid-cols-3 gap-3 border-t border-gray-200 pt-4 text-sm dark:border-gray-800">
      {metrics.map((metric) => (
        <div class="rounded-md border border-gray-200 bg-white/70 p-3 dark:border-gray-800 dark:bg-gray-950/70">
          <div class:list={['font-mono text-lg font-extrabold', toneClass[metric.tone ?? 'blue']]}>
            {metric.value}
          </div>
          <div class="mt-1 text-xs font-semibold text-gray-500 dark:text-gray-400">{metric.label}</div>
        </div>
      ))}
    </div>
  )}

  {rows.length > 0 && (
    <div class="mt-5 grid gap-x-4 gap-y-3 border-t border-gray-200 pt-4 text-sm dark:border-gray-800 sm:grid-cols-2">
      {rows.map((row) => (
        <div>
          <div class="font-bold text-gray-950 dark:text-white">{row.label}</div>
          <div class="text-gray-500 dark:text-gray-400">{row.value}</div>
        </div>
      ))}
    </div>
  )}
</aside>
