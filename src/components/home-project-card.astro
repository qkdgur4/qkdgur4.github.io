---
interface ProjectLink {
  label: string;
  href: string;
}

interface ProjectVisual {
  src: string;
  alt: string;
}

interface Props {
  title: string;
  summary: string;
  status: string;
  category: string;
  date: string;
  role: string;
  stack: string[];
  links: ProjectLink[];
  visual: ProjectVisual;
  featured?: boolean;
}

const {
  title,
  summary,
  status,
  category,
  date,
  role,
  stack,
  links,
  visual,
  featured = false,
} = Astro.props;
---

<article class:list={[
  'group flex h-full flex-col overflow-hidden rounded-lg border bg-white/70 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-blue-500/10 dark:bg-gray-900/70',
  featured
    ? 'border-blue-200 dark:border-blue-500/40'
    : 'border-gray-200 dark:border-gray-800',
]}>
  <a href={links[0]?.href ?? '/projects'} class="block">
    <div class="relative h-44 overflow-hidden border-b border-gray-200 bg-gray-100 dark:border-gray-800 dark:bg-gray-950">
      <img
        src={visual.src}
        alt={visual.alt}
        loading="lazy"
        class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
      />
      <div class="absolute left-4 top-4 flex items-center gap-2 rounded-full border border-white/60 bg-white/90 px-3 py-1 text-xs font-bold text-gray-800 shadow-sm backdrop-blur dark:border-gray-700/80 dark:bg-gray-950/80 dark:text-gray-100">
        <span class:list={[
          'h-2 w-2 rounded-full',
          status.toLowerCase().includes('built') || status.toLowerCase().includes('live')
            ? 'bg-emerald-500'
            : 'bg-blue-500',
        ]}></span>
        {status}
      </div>
    </div>
  </a>

  <div class="flex flex-1 flex-col p-5">
    <div class="mb-3 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs font-semibold text-gray-500 dark:text-gray-400">
      <span class="text-blue-600 dark:text-blue-300">{category}</span>
      <span aria-hidden="true">•</span>
      <span>{date}</span>
    </div>

    <h3 class="text-xl font-extrabold text-gray-950 transition-colors group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-300">
      {title}
    </h3>
    <p class="mt-3 line-clamp-4 flex-1 text-sm leading-relaxed text-gray-600 dark:text-gray-300">
      {summary}
    </p>

    <div class="mt-4 rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-xs font-semibold text-gray-600 dark:border-gray-800 dark:bg-gray-950/60 dark:text-gray-300">
      {role}
    </div>

    <div class="mt-4 flex flex-wrap gap-2">
      {stack.map((item) => (
        <span class="rounded-md border border-emerald-200 bg-emerald-50 px-2.5 py-1 text-xs font-semibold text-emerald-700 dark:border-emerald-500/20 dark:bg-emerald-500/10 dark:text-emerald-300">
          {item}
        </span>
      ))}
    </div>

    <div class="mt-5 flex flex-wrap gap-3 border-t border-gray-200 pt-4 dark:border-gray-800">
      {links.map((link) => (
        <a
          href={link.href}
          target={link.href.startsWith('http') ? '_blank' : undefined}
          rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          class="inline-flex items-center gap-1 text-sm font-bold text-gray-700 transition-colors hover:text-blue-600 dark:text-gray-200 dark:hover:text-blue-300"
        >
          {link.label}
          <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M5.25 3.25A.75.75 0 0 1 6 2.5h6.25a.75.75 0 0 1 .75.75V9.5a.75.75 0 0 1-1.5 0V5.06l-7.22 7.22a.75.75 0 0 1-1.06-1.06l7.22-7.22H6a.75.75 0 0 1-.75-.75Z" />
          </svg>
        </a>
      ))}
    </div>
  </div>
</article>
