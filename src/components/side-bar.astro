---
const { sideBarActiveItemID } = Astro.props;
const activeClass = "bg-blue-100 dark:bg-blue-900/40 text-blue-600 dark:text-blue-300 border-r-4 border-blue-500"; // Active item style
const inactiveClass = "text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white transition-colors";
---

<!-- Desktop Sidebar (Fixed on lg screens, hidden on smaller) -->
<aside class="hidden lg:flex flex-col w-72 h-screen fixed left-0 top-0 bg-white/80 dark:bg-gray-900/80 backdrop-blur-xl border-r border-gray-200 dark:border-gray-800 py-8 px-6 z-40 transition-colors duration-300">
  
  <!-- Profile Avatar & Title -->
  <div class="flex flex-col items-center mb-10">
    <div class="w-32 h-32 rounded-full overflow-hidden border-4 border-gray-100 dark:border-gray-800 shadow-xl mb-4 transition-colors">
      <img src="/profile.png" alt="Profile" class="w-full h-full object-cover" />
    </div>
    <a href="/" class="text-2xl font-bold text-gray-900 dark:text-white tracking-wide hover:text-blue-500 dark:hover:text-blue-400 transition-colors">
      qkdgur4
    </a>
    <p class="mt-2 text-center text-sm text-gray-500 dark:text-gray-400">Backend / Infra / Simulation</p>
  </div>

  <!-- Navigation Links -->
  <nav class="flex flex-col space-y-2 text-base font-medium transition-colors">
    <a href="/" class={`px-4 py-3 rounded-xl ${sideBarActiveItemID === 'home' ? activeClass : inactiveClass}`}>Home</a>
    <a href="/projects" class={`px-4 py-3 rounded-xl ${sideBarActiveItemID === 'projects' ? activeClass : inactiveClass}`}>Projects</a>
    <a href="/blog" class={`px-4 py-3 rounded-xl ${sideBarActiveItemID === 'blog' ? activeClass : inactiveClass}`}>Blog</a>
    <a href="/categories" class={`px-4 py-3 rounded-xl ${sideBarActiveItemID === 'categories' ? activeClass : inactiveClass}`}>Categories</a>
    <a href="/archives" class={`px-4 py-3 rounded-xl ${sideBarActiveItemID === 'archives' ? activeClass : inactiveClass}`}>Archives</a>
    <a href="/tags" class={`px-4 py-3 rounded-xl ${sideBarActiveItemID === 'tags' ? activeClass : inactiveClass}`}>Tags</a>
    <a href="/about" class={`px-4 py-3 rounded-xl ${sideBarActiveItemID === 'about' ? activeClass : inactiveClass}`}>About</a>
  </nav>

  <!-- Social Links -->
  <div class="pt-6 border-t border-gray-200 dark:border-gray-800 flex justify-center gap-4 transition-colors">
    <a href="https://github.com/qkdgur4" target="_blank" rel="noopener noreferrer" class="text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors" aria-label="GitHub profile">
      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
      </svg>
    </a>
    <a href="/rss.xml" class="text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors" aria-label="RSS feed">
      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M6.18 17.82a2.18 2.18 0 1 1-4.36 0 2.18 2.18 0 0 1 4.36 0Z"></path>
        <path d="M2 8.18v3.05c5.95 0 10.77 4.82 10.77 10.77h3.05C15.82 14.36 9.64 8.18 2 8.18Z"></path>
        <path d="M2 2v3.05c9.36 0 16.95 7.59 16.95 16.95H22C22 10.95 13.05 2 2 2Z"></path>
      </svg>
    </a>
  </div>
</aside>
