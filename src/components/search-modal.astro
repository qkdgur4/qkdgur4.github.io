---
---
<div id="search-modal" class="fixed inset-0 z-50 hidden opacity-0 transition-opacity duration-300">
  <!-- Backdrop -->
  <div id="search-backdrop" class="absolute inset-0 bg-gray-900/50 backdrop-blur-sm cursor-pointer"></div>
  
  <!-- Modal Content -->
  <div class="absolute top-16 left-1/2 -translate-x-1/2 w-[90%] max-w-2xl">
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-2xl border border-gray-200 dark:border-gray-700 overflow-hidden flex flex-col max-h-[80vh] transition-colors duration-300">
      
      <!-- Search Input -->
      <div class="flex items-center px-4 py-3 border-b border-gray-200 dark:border-gray-700 transition-colors bg-white dark:bg-gray-800">
        <svg class="w-6 h-6 text-gray-400 dark:text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
        <input 
          type="text" 
          id="search-input" 
          class="w-full bg-transparent border-none focus:outline-none focus:ring-0 text-gray-900 dark:text-white px-4 text-lg placeholder-gray-400 dark:placeholder-gray-500 transition-colors" 
          placeholder="Search articles... (Press '/' to focus)" 
          autocomplete="off"
        />
        <button id="search-close-btn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors shrink-0 p-1">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <!-- Search Results -->
      <div id="search-results" class="overflow-y-auto p-2 space-y-1 hidden bg-gray-50/50 dark:bg-gray-900/20">
        <!-- Results will be injected here via JS -->
      </div>
      
      <!-- Empty State / Loading State -->
      <div id="search-empty" class="p-8 text-center text-gray-500 dark:text-gray-400 transition-colors bg-gray-50/50 dark:bg-gray-900/20">
        Type to start searching...
      </div>
      
      <!-- Footer hint -->
      <div class="px-4 py-2 bg-gray-100 dark:bg-gray-900 border-t border-gray-200 dark:border-gray-700 text-xs text-gray-500 dark:text-gray-400 flex justify-between items-center transition-colors">
        <span>Search by title, description, category, or tags</span>
        <span class="hidden sm:inline">ESC to close</span>
      </div>
    </div>
  </div>
</div>

<script>
  // Declare a global variable to cache search data across page transitions
  if (typeof window.searchDataCache === 'undefined') {
    window.searchDataCache = null;
  }

  document.addEventListener('astro:page-load', () => {
    const searchModal = document.getElementById('search-modal');
    if (!searchModal) return; // Prevent errors if modal isn't on the page
    
    const searchBackdrop = document.getElementById('search-backdrop');
    const searchInput = document.getElementById('search-input');
    const searchResults = document.getElementById('search-results');
    const searchEmpty = document.getElementById('search-empty');
    const searchCloseBtn = document.getElementById('search-close-btn');

    // Fetch search data only once per session
    async function fetchSearchData() {
      if (window.searchDataCache) return;
      try {
        const res = await fetch('/api/search.json');
        window.searchDataCache = await res.json();
      } catch (e) {
        console.error('Failed to fetch search data', e);
      }
    }

    // Open modal
    async function openSearch() {
      searchModal.classList.remove('hidden');
      // small delay for transition
      setTimeout(() => {
        searchModal.classList.remove('opacity-0');
        searchInput.focus();
      }, 10);
      
      // Fetch data in background when opened
      await fetchSearchData();
    }

    // Close modal
    function closeSearch() {
      searchModal.classList.add('opacity-0');
      setTimeout(() => {
        searchModal.classList.add('hidden');
        searchInput.value = '';
        searchResults.innerHTML = '';
        searchResults.classList.add('hidden');
        searchEmpty.classList.remove('hidden');
        searchEmpty.textContent = 'Type to start searching...';
      }, 300);
    }

    // Handle Search logic
    function handleSearch(e) {
      const query = e.target.value.toLowerCase().trim();
      
      if (!query) {
        searchResults.innerHTML = '';
        searchResults.classList.add('hidden');
        searchEmpty.classList.remove('hidden');
        searchEmpty.textContent = 'Type to start searching...';
        return;
      }

      if (!window.searchDataCache) {
        searchEmpty.textContent = 'Loading...';
        return;
      }

      // Filter data
      const results = window.searchDataCache.filter(post => 
        post.title.toLowerCase().includes(query) || 
        post.description.toLowerCase().includes(query) ||
        post.category.toLowerCase().includes(query) ||
        post.tags.some(tag => tag.toLowerCase().includes(query))
      );

      if (results.length === 0) {
        searchResults.innerHTML = '';
        searchResults.classList.add('hidden');
        searchEmpty.classList.remove('hidden');
        searchEmpty.textContent = 'No results found for "' + query + '"';
        return;
      }

      // Render results
      searchEmpty.classList.add('hidden');
      searchResults.classList.remove('hidden');
      
      searchResults.innerHTML = results.map(post => `
        <a href="/blog/${post.id}" class="block p-3 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700/50 transition-colors group">
          <h4 class="text-base font-bold text-gray-900 dark:text-white mb-1 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">${post.title}</h4>
          <div class="flex items-center gap-2 mb-1">
            <span class="text-xs font-semibold px-2 py-0.5 rounded bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400">${post.category}</span>
            ${post.tags.slice(0, 3).map(tag => `<span class="text-xs text-gray-500 dark:text-gray-400">#${tag}</span>`).join('')}
          </div>
          <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-1">${post.description}</p>
        </a>
      `).join('');
    }

    // Attach open event to all triggers (Using global delegate to avoid duplicate listeners)
    const handleDocumentClick = (e) => {
      if (e.target.closest('.search-trigger-btn')) {
        openSearch();
      }
    };
    
    // Remove old listeners to prevent duplicates on page navigation
    document.removeEventListener('click', window._searchClickHandler);
    window._searchClickHandler = handleDocumentClick;
    document.addEventListener('click', window._searchClickHandler);

    // Event Listeners
    searchCloseBtn?.addEventListener('click', closeSearch);
    searchBackdrop?.addEventListener('click', closeSearch);
    searchInput?.addEventListener('input', handleSearch);

    // Keyboard shortcuts
    const handleKeydown = (e) => {
      if (e.key === 'Escape' && !searchModal.classList.contains('hidden')) {
        closeSearch();
      }
      // Open on Cmd+K or Ctrl+K
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        openSearch();
      }
      // Open on '/' if not in an input
      if (e.key === '/' && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') {
        e.preventDefault();
        openSearch();
      }
    };
    
    document.removeEventListener('keydown', window._searchKeyHandler);
    window._searchKeyHandler = handleKeydown;
    document.addEventListener('keydown', window._searchKeyHandler);
  });
</script>
