---
import BaseLayout from './base-layout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  tags: string[];
  heroImage?: string;
}

const { title, description, pubDate, updatedDate, category, tags, heroImage } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} | qkdgur4`} description={description} sideBarActiveItemID="blog">
  <article class="py-12 max-w-3xl mx-auto">
    <!-- Post Header -->
    <header class="mb-10 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 text-sm font-medium mb-6 transition-colors">
        <span>{category}</span>
      </div>

      <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 dark:text-white mb-6 leading-tight transition-colors" transition:name={`post-title-${title}`}>
        {title}
      </h1>

      <div class="flex items-center justify-center gap-4 text-gray-500 dark:text-gray-400 font-medium transition-colors">
        <time datetime={pubDate.toISOString()}>
          {formattedDate}
        </time>
        {updatedDate && (
          <span>
            (수정: {formattedUpdatedDate})
          </span>
        )}
      </div>

      <p class="text-gray-600 dark:text-gray-400 text-lg mt-6">{description}</p>

      <!-- Tags -->
      <div class="flex flex-wrap justify-center gap-2 mt-8">
        {tags.map((tag) => (
          <a
            href={`/tags/${tag}`}
            class="text-xs text-gray-600 dark:text-gray-300 bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 px-3 py-1 rounded-full hover:border-blue-500 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
          >
            #{tag}
          </a>
        ))}
      </div>
    </header>

    <!-- Post Body -->
    <div class="prose prose-blue dark:prose-invert prose-lg max-w-none transition-colors
                dark:prose-headings:text-gray-100 prose-headings:text-gray-900
                dark:prose-a:text-blue-400 prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline
                dark:prose-code:text-emerald-400 prose-code:text-emerald-600 dark:prose-code:bg-gray-800 prose-code:bg-gray-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:before:content-none prose-code:after:content-none
                dark:prose-pre:bg-gray-950 prose-pre:bg-gray-50 prose-pre:border dark:prose-pre:border-gray-800 prose-pre:border-gray-200 prose-pre:rounded-lg
                dark:prose-blockquote:border-blue-500 prose-blockquote:border-blue-600 dark:prose-blockquote:text-gray-300 prose-blockquote:text-gray-700
                dark:prose-strong:text-gray-100 prose-strong:text-gray-900
                prose-img:rounded-lg shadow-sm">
      <slot />
    </div>

    <!-- Back to Blog -->
    <div class="mt-16 pt-8 border-t border-gray-200 dark:border-gray-800 transition-colors">
      <a
        href="/blog"
        class="text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors inline-flex items-center gap-2 font-medium"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        전체 글 목록으로 돌아가기
      </a>
    </div>
  </article>
</BaseLayout>
