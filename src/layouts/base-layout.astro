---
import { ClientRouter } from 'astro:transitions';
import SeoHead from '../components/seo-head.astro';
import SideBar from '../components/side-bar.astro';
import Footer from '../components/footer.astro';
import TopRightHeader from '../components/top-right-header.astro';
import SearchModal from '../components/search-modal.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  sideBarActiveItemID?: 'home' | 'projects' | 'blog' | 'tags' | 'about';
}

const { title, description, sideBarActiveItemID = 'home' } = Astro.props;
---

<!doctype html>
<html lang="ko" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <SeoHead title={title} description={description} />
    <ClientRouter />
    <!-- Dark Mode Init Script (Prevents FOUC) -->
    <script is:inline>
      if (typeof localStorage !== 'undefined') {
        const theme = localStorage.getItem('theme');
        if (theme === 'light') {
          document.documentElement.classList.remove('dark');
        } else {
          document.documentElement.classList.add('dark');
        }
      } else {
        // Default to dark unconditionally
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen antialiased transition-colors duration-300 selection:bg-blue-500/30 selection:text-blue-200">
    <!-- Mobile Header -->
    <div class="lg:hidden w-full bg-white/90 dark:bg-gray-900/90 backdrop-blur-md border-b border-gray-200 dark:border-gray-800 p-4 sticky top-0 z-50 flex items-center justify-between transition-colors duration-300">
      <a href="/" class="text-xl font-bold text-gray-900 dark:text-white">DevBlog</a>
      <div class="flex items-center gap-4">
        <TopRightHeader />
        <button id="mobile-menu-btn" class="text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Drawer Overlay -->
    <div id="mobile-drawer" class="fixed inset-0 bg-white/95 dark:bg-gray-900/95 z-50 transform translate-x-full transition-transform duration-300 lg:hidden flex flex-col pt-16 px-6">
      <button id="mobile-close-btn" class="absolute top-4 right-4 text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
      <nav class="flex flex-col space-y-4 text-xl font-medium">
        <a href="/" class="text-gray-900 dark:text-white hover:text-blue-500 dark:hover:text-blue-400 transition-colors">Home</a>
        <a href="/projects" class="text-gray-900 dark:text-white hover:text-blue-500 dark:hover:text-blue-400 transition-colors">Projects</a>
        <a href="/blog" class="text-gray-900 dark:text-white hover:text-blue-500 dark:hover:text-blue-400 transition-colors">Blog</a>
        <a href="/categories" class="text-gray-900 dark:text-white hover:text-blue-500 dark:hover:text-blue-400 transition-colors">Categories</a>
        <a href="/archives" class="text-gray-900 dark:text-white hover:text-blue-500 dark:hover:text-blue-400 transition-colors">Archives</a>
        <a href="/tags" class="text-gray-900 dark:text-white hover:text-blue-500 dark:hover:text-blue-400 transition-colors">Tags</a>
        <a href="/about" class="text-gray-900 dark:text-white hover:text-blue-500 dark:hover:text-blue-400 transition-colors">About</a>
      </nav>
    </div>

    <SideBar sideBarActiveItemID={sideBarActiveItemID} />
    
    <div class="lg:ml-72 flex flex-col min-h-screen transition-colors duration-300">
      <!-- Desktop Top Header -->
      <div class="hidden lg:flex justify-end p-6">
        <TopRightHeader />
      </div>
      
      <main class="flex-grow w-full max-w-4xl mx-auto px-6 pb-8">
        <slot />
      </main>
      <Footer />
    </div>

    <SearchModal />
    <script>
      document.addEventListener('astro:page-load', () => {
        const btn = document.getElementById('mobile-menu-btn');
        const closeBtn = document.getElementById('mobile-close-btn');
        const drawer = document.getElementById('mobile-drawer');

        btn?.addEventListener('click', () => {
          drawer?.classList.remove('translate-x-full');
        });

        closeBtn?.addEventListener('click', () => {
          drawer?.classList.add('translate-x-full');
        });
      });
    </script>
  </body>
</html>
