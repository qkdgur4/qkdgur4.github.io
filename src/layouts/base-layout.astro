---
import { ClientRouter } from 'astro:transitions';
import SeoHead from '../components/seo-head.astro';
import SideBar from '../components/side-bar.astro';
import Footer from '../components/footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  sideBarActiveItemID?: 'home' | 'projects' | 'blog' | 'tags' | 'about';
}

const { title, description, sideBarActiveItemID = 'home' } = Astro.props;
---

<!doctype html>
<html lang="ko" class="dark">
  <head>
    <SeoHead title={title} description={description} />
    <ClientRouter />
  </head>
  <body class="bg-gray-900 text-gray-100 min-h-screen antialiased selection:bg-blue-500/30 selection:text-blue-200">
    <!-- Mobile Header -->
    <div class="lg:hidden w-full bg-gray-900/90 backdrop-blur-md border-b border-gray-800 p-4 sticky top-0 z-50 flex items-center justify-between">
      <a href="/" class="text-xl font-bold text-white">DevBlog</a>
      <button id="mobile-menu-btn" class="text-gray-400 hover:text-white">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Drawer Overlay -->
    <div id="mobile-drawer" class="fixed inset-0 bg-gray-900/95 z-50 transform translate-x-full transition-transform duration-300 lg:hidden flex flex-col pt-16 px-6">
      <button id="mobile-close-btn" class="absolute top-4 right-4 text-gray-400 hover:text-white">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
      <nav class="flex flex-col space-y-4 text-xl font-medium">
        <a href="/" class="text-white hover:text-blue-400">Home</a>
        <a href="/projects" class="text-white hover:text-blue-400">Projects</a>
        <a href="/blog" class="text-white hover:text-blue-400">Blog</a>
        <a href="/tags" class="text-white hover:text-blue-400">Tags</a>
        <a href="/about" class="text-white hover:text-blue-400">About</a>
      </nav>
    </div>

    <SideBar sideBarActiveItemID={sideBarActiveItemID} />
    
    <div class="lg:ml-72 flex flex-col min-h-screen">
      <main class="flex-grow w-full max-w-4xl mx-auto px-6 py-8">
        <slot />
      </main>
      <Footer />
    </div>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const closeBtn = document.getElementById('mobile-close-btn');
      const drawer = document.getElementById('mobile-drawer');

      btn?.addEventListener('click', () => {
        drawer?.classList.remove('translate-x-full');
      });

      closeBtn?.addEventListener('click', () => {
        drawer?.classList.add('translate-x-full');
      });
    </script>
  </body>
</html>
